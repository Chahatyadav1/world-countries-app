<?xml version="1.0" encoding="UTF-8"?>
<suppressions xmlns="https://jeremylong.github.io/DependencyCheck/dependency-suppression.1.3.xsd">

    <!--
        CVE-2014-8180 affects the MongoDB SERVER on Red Hat Satellite 6 (empty-password auth bypass).
        It does NOT affect the mongodb npm driver package (pkg:npm/mongodb).
        This is a false positive from the NVD CPE match.
        Reference: https://nvd.nist.gov/vuln/detail/CVE-2014-8180
    -->
    <suppress>
        <notes>
            CVE-2014-8180 is a server-side vulnerability in MongoDB on Red Hat Satellite 6.
            It does not affect the mongodb npm driver. This is a false positive.
        </notes>
        <packageUrl regex="true">^pkg:npm/mongodb@.*$</packageUrl>
        <cve>CVE-2014-8180</cve>
    </suppress>

    <!--
        CVE-2017-16115 affects time-span npm package (ReDoS vulnerability).
        No patched version exists on npm (latest is 5.1.0 as of 2026).
        This package is a transitive dependency only, pulled in via:
          chai-http -> is-ip -> super-regex -> time-span
        User input to this app never flows through time-span directly.
        Reference: https://nvd.nist.gov/vuln/detail/CVE-2017-16115
    -->
    <suppress>
        <notes>
            CVE-2017-16115 is a ReDoS in time-span. No patched version exists on npm.
            time-span is a deep transitive dependency not exposed to untrusted user input.
        </notes>
        <packageUrl regex="true">^pkg:npm/time-span@.*$</packageUrl>
        <cve>CVE-2017-16115</cve>
    </suppress>
<suppress>
    <notes>
        CVE-2025-12657 is a server-side KMIP parser vulnerability in MongoDB Server binaries.
        It does not affect the mongodb npm driver. This is a false positive.
    </notes>
    <packageUrl regex="true">^pkg:npm/mongodb@.*$</packageUrl>
    <cve>CVE-2025-12657</cve>
</suppress>
</suppressions>