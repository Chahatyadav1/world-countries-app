{
  "name": "World Countries",
  "version": "1.0.0",
  "description": "World Countries REST API with CI/CD pipeline",
  "license": "MIT",
  "scripts": {
    "start": "node app.js",
    "test": "NODE_ENV=test mocha app-test.js --timeout 10000 --reporter spec --exit",
    "test:ci": "NODE_ENV=test mocha app-test.js --timeout 10000 --reporter xunit --reporter-options output=./test-results.xml --exit",
    "coverage": "NODE_ENV=test nyc --reporter cobertura --reporter lcov --reporter text --reporter json-summary mocha app-test.js --timeout 10000 --reporter xunit --reporter-options output=./test-results.xml --exit"
  },
  "nyc": {
    "check-coverage": true,
    "lines": 60
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "mocha-junit-reporter": "^2.2.1",
    "mongodb": "^6.5.0",
    "mongoose": "^9.3.1",
    "nyc": "^15.1.0",
    "serverless-http": "^3.2.0"
  },
  "devDependencies": {
    "chai": "^4.4.1",
    "chai-http": "^4.4.0",
    "mocha": "^10.7.3"
  },
  "overrides": {
    "serialize-javascript": ">=7.0.3",
    "diff": ">=8.0.3",
    "super-regex": ">=1.1.0"
  }
}